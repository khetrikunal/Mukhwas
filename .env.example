# ── The Royal Mukhwas — environment configuration ────────────────────────────
# Copy this file to `.env` (next to docker-compose.yml) and fill in real values.
# NEVER commit the real .env file — it is gitignored.

# Database
DB_NAME=royalmukhwas
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-password

# JWT — use a random string of AT LEAST 32 characters.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Razorpay dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# Transactional email (Gmail app password — NOT your account password)
MAIL_USERNAME=
MAIL_PASSWORD=

# Frontend (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── SECURITY NOTE ───────────────────────────────────────────────────────────
# If you are setting this up after the initial commit, the following secrets
# were previously hardcoded in application.properties and MUST be rotated
# (revoked + regenerated) in each provider's dashboard:
#   - Gmail app password  (theroyakmukhwassupport@gmail.com)
#   - Database password
#   - JWT signing secret
# Stripping them from version control does NOT invalidate already-leaked values.
